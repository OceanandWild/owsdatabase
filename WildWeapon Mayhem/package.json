{
  "name": "wildweapon-mayhem",
  "version": "2026.5.2-t0012",
  "description": "WildWeapon Mayhem for Windows (Electron build)",
  "main": "main.js",
  "author": "Ocean and Wild Studios",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "version:stamp": "node scripts/stamp-version.js",
    "dist": "npm run version:stamp && electron-builder --win nsis --publish never",
    "dist:portable": "npm run version:stamp && electron-builder --win portable --publish never",
    "fix:taskbar-icon": "powershell -NoProfile -ExecutionPolicy Bypass -File fix-taskbar-icon.ps1"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.oceanwildstudios.wildweaponmayhem",
    "detectUpdateChannel": false,
    "publish": {
      "provider": "generic",
      "url": "https://github.com/OceanandWild/wildweapon-mayhem/releases/latest/download"
    },
    "productName": "WildWeapon Mayhem",
    "directories": {
      "output": "C:/builds/wildweapon-mayhem"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "wildweaponmayhem.ico",
      "assets/**/*",
      "ai_trainer/**/*",
      "license_agreement.rtf"
    ],
    "extraResources": [
      {
        "from": "wildweaponmayhem.ico",
        "to": "wildweaponmayhem.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "WildWeapon Mayhem",
      "icon": "wildweaponmayhem.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WildWeapon Mayhem",
      "artifactName": "WildWeapon.Mayhem.Setup.${version}.exe",
      "include": "build/installer.nsh"
    }
  }
}
