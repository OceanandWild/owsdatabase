{
    "name":  "ows-store",
    "version":  "2026.4.19-t2139",
    "description":  "OWS Store - Central Studio Hub",
    "main":  "main.js",
    "author":  "Ocean and Wild Studios",
    "license":  "MIT",
    "dependencies":  {
                         "@capacitor/android":  "^8.1.0",
                         "@capacitor/app":  "^8.0.1",
                         "@capacitor/core":  "^8.1.0",
                         "@capacitor/file-transfer":  "^2.0.4",
                         "@capacitor/filesystem":  "^8.1.2",
                         "@capacitor/push-notifications":  "^8.0.3",
                         "@capawesome-team/capacitor-file-opener":  "^8.0.1",
                         "electron-updater":  "^6.1.7"
                     },
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder",
                    "dist":  "electron-builder --win nsis --publish never",
                    "dist:nsis":  "electron-builder --win nsis --publish never",
                    "dist:appx":  "electron-builder --win appx --publish never",
                    "dist:portable":  "electron-builder --win portable --publish never",
                    "fix:taskbar-icon":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-taskbar-icon.ps1"
                },
    "devDependencies":  {
                            "@capacitor/cli":  "^8.1.0",
                            "electron":  "^28.0.0",
                            "electron-builder":  "^24.9.1"
                        },
    "build":  {
                  "appId":  "com.oceanwildstudios.nexusstore",
                  "detectUpdateChannel":  false,
                  "publish":  {
                                  "provider":  "generic",
                                  "url":  "https://github.com/OceanandWild/owsdatabase/releases/latest/download"
                              },
                  "productName":  "OWS Store",
                  "directories":  {
                                      "output":  "C:/builds/ows-store",
                                      "buildResources":  "build"
                                  },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "index.html",
                                "build/icon.ico",
                                "build/wildweaponmayhem.ico",
                                "build/ssa.ico",
                                "build/oceanpay.ico",
                                "build/floretshop.ico",
                                "build/wildtransfer.ico",
                                "build/owsnews.ico",
                                "build/wilddestiny.ico",
                                "build/velocitysurge.ico",
                                "build/wildwave.ico",
                                "build/wildwave.png",
                                "build/awqg.ico",
                                "build/ecoxion.ico",
                                "build/dinobox.ico",
                                "build/wildshorts.jpg",
                                "build/oceancinemas.jpg"
                            ],
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             },
                                             {
                                                 "target":  "appx",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "executableName":  "OWS Store",
                              "icon":  "build/icon.ico",
                              "signAndEditExecutable":  true
                          },
                  "appx":  {
                               "identityName":  "OceanandWild.OWSStore",
                               "applicationId":  "OWSStore",
                               "publisher":  "CN=OceanandWildStudios",
                               "publisherDisplayName":  "Ocean and Wild Studios",
                               "displayName":  "OWS Store",
                               "backgroundColor":  "#020617"
                           },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "include":  "build/installer.nsh",
                               "artifactName":  "OWS.Store.Setup.${version}.exe",
                               "installerIcon":  "build/icon.ico",
                               "uninstallerIcon":  "build/icon.ico",
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "OWS Store"
                           }
              }
}
