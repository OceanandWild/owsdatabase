{
    "name": "ecoxion",
    "version": "2026.3.15-t1500",
    "description": "Ecoxion - OWS Ecosystem App",
    "main": "main.js",
    "author": "Ocean and Wild Studios",
    "license": "MIT",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder --win nsis --publish never",
        "dist:nsis": "electron-builder --win nsis --publish never",
        "dist:portable": "electron-builder --win portable --publish never"
    },
    "dependencies": {
        "electron-updater": "^6.1.7"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.oceanandwild.ecoxion",
        "detectUpdateChannel": false,
        "publish": {
            "provider": "generic",
            "url": "https://github.com/OceanandWild/ecoxion/releases/latest/download"
        },
        "productName": "Ecoxion",
        "directories": {
            "output": "C:/builds/ecoxion",
            "buildResources": "build"
        },
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "build/ecoxion.ico"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "executableName": "Ecoxion",
            "icon": "build/ecoxion.ico",
            "signAndEditExecutable": true
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "artifactName": "Ecoxion.Setup.${version}.exe",
            "installerIcon": "build/ecoxion.ico",
            "uninstallerIcon": "build/ecoxion.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Ecoxion"
        }
    }
}
