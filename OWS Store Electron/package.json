{
  "name": "ows-store",
  "version": "2026.3.10-t0750",
  "description": "OWS Store - Central Studio Hub",
  "main": "main.js",
  "author": "Ocean and Wild Studios",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.oceanwildstudios.nexusstore",
    "detectUpdateChannel": false,
    "productName": "OWS Store",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "build/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "OWS Store",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "artifactName": "OWS.Store.Setup.${version}.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OWS Store"
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/OceanandWild/owsdatabase/releases/latest/download"
    }
  }
}
