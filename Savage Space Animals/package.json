{
  "name": "savage-space-animals",
  "version": "2026.2.23-t210015",
  "description": "Savage Space Animals for Windows (Electron build)",
  "main": "main.js",
  "author": "Ocean and Wild Studios",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "version:stamp": "node scripts/stamp-version.js",
    "dist": "npm run version:stamp && electron-builder --win nsis --publish never",
    "dist:portable": "npm run version:stamp && electron-builder --win portable --publish never",
    "fix:taskbar-icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-taskbar-icon.ps1"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.oceanwildstudios.savagespaceanimals",
    "detectUpdateChannel": false,
    "publish": {
      "provider": "generic",
      "url": "https://github.com/OceanandWild/savagespaceanimals/releases/latest/download"
    },
    "productName": "Savage Space Animals",
    "directories": {
      "output": "C:/builds/savage-space-animals",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "Savage Space Animals",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Savage Space Animals",
      "artifactName": "Savage.Space.Animals.Setup.${version}.exe"
    }
  }
}
